## Companion change: `ctx.knownBlockers` and `ctx.upcomingMilestones` (F6)

Add a context-builder pass that reads `~/.claude/primer.md` `## Open Blockers` plus active
DIST issues, and exposes them on `ctx`:

```javascript
// Insert near where ctx is built (around line 1750–1850 in run()).

import { homedir } from "os";

function readPrimerBlockers() {
  const primerPath = resolve(homedir(), ".claude", "primer.md");
  if (!existsSync(primerPath)) return [];
  const text = readFileSync(primerPath, "utf8");
  const m = text.match(/##\s*Open Blockers\s*\n+([\s\S]*?)(?=\n## |$)/);
  if (!m) return [];
  return m[1]
    .split("\n")
    .map((l) => l.replace(/^\s*[-*]\s*/, "").trim())
    .filter(Boolean);
}

// In run(), after ctx is built:
ctx.knownBlockers = [
  ...readPrimerBlockers(),
  ...(ctx.jiraProjectSnapshots ?? [])
    .flatMap((s) => s.issues)
    .filter((i) => i.key.startsWith("DIST-") && i.status?.toLowerCase() !== "done")
    .map((i) => `${i.key}: ${i.summary} (${i.status})`),
];

ctx.upcomingMilestones = [
  // Pull from Confluence release pages or hard-code monthly cadence
  ...(ctx.confluenceReleases ?? []).slice(0, 5),
];

ctx.oooBlocks = (ctx.calendarEvents ?? [])
  .filter((e) => /OOO|Out of Office|Annual Leave/i.test(e.subject ?? ""))
  .filter((e) => (new Date(e.end) - new Date(e.start)) / 86400000 >= 2)
  .map((e) => `${e.subject}: ${e.startDate} – ${e.endDate}`);
```

