modules = ["nodejs-20"]

[nix]
channel = "stable-23_11"

run = "git pull --quiet || true && cd dashboard && npm install && npx next build && npx next start -p 3000"

[deployment]
run = ["bash", "-l", "-c", "cd dashboard && npx next start -p 3000"]
build = ["bash", "-l", "-c", "cd dashboard && npm install && npx next build"]
visibility = "private"

[[ports]]
localPort = 3000
externalPort = 80
